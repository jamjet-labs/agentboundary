{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentboundary.dev/schemas/action-receipt-v0.1.json",
  "title": "AgentBoundary Action Receipt v0.1",
  "description": "Portable, tamper-evident proof of an AI-initiated production action. Emitted at the production action boundary; verifiable by any party (auditor, regulator, insurer) without trusting the agent framework or model provider.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "receipt_id",
    "issued_at",
    "actor",
    "agent",
    "tool",
    "target",
    "arguments_hash",
    "policy",
    "execution",
    "receipt_hash"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "agentboundary/v0.1",
      "description": "Schema version literal."
    },
    "receipt_id": {
      "type": "string",
      "format": "uuid",
      "description": "Globally unique receipt identifier (UUID v4 or v7 recommended)."
    },
    "issued_at": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 timestamp when the receipt was emitted."
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["human", "system", "agent"]
        },
        "id": { "type": "string", "minLength": 1 },
        "display_name": { "type": "string" }
      }
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["framework", "framework_version", "model"],
      "properties": {
        "framework": { "type": "string", "minLength": 1 },
        "framework_version": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "model_version": { "type": "string" }
      }
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "capability"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string" },
        "capability": {
          "type": "string",
          "minLength": 1,
          "description": "Dotted-namespace capability identifier, e.g. 'github.merge', 'stripe.refund', 'spring.service.mutation'."
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["system", "environment"],
      "properties": {
        "system": { "type": "string", "minLength": 1 },
        "environment": {
          "type": "string",
          "enum": ["prod", "staging", "dev"]
        },
        "resource_id": { "type": "string" }
      }
    },
    "arguments_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "Lowercase hex SHA-256 of canonicalized arguments. Proves the executed arguments match what was approved."
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "decision"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "decision": {
          "type": "string",
          "enum": ["allow", "deny", "escalate", "require-approval"]
        }
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approver", "approved_at"],
      "properties": {
        "approver": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id"],
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "display_name": { "type": "string" },
            "role": { "type": "string" }
          }
        },
        "approved_at": { "type": "string", "format": "date-time" },
        "context": { "type": "string" }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "completed_at"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["success", "failure", "blocked"]
        },
        "completed_at": { "type": "string", "format": "date-time" },
        "error_code": { "type": "string" },
        "result_ref": { "type": "string" }
      }
    },
    "receipt_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "Lowercase hex SHA-256 of all preceding fields canonicalized (sorted keys, no whitespace, UTF-8). Tamper-evidence anchor."
    }
  },
  "allOf": [
    {
      "if": {
        "required": ["policy"],
        "properties": {
          "policy": {
            "required": ["decision"],
            "properties": {
              "decision": { "const": "require-approval" }
            }
          }
        }
      },
      "then": {
        "required": ["approval"]
      }
    }
  ]
}
